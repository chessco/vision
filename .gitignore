# =========================================================================
# Pitaya Visual Creative Suite - .gitignore
# =========================================================================

# -------------------------------------------------------------------------
# Secrets & Environments (¡NUNCA SUBIR A GITHUB!)
# -------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.cert.pem
*.pkcs12
*.p12

# -------------------------------------------------------------------------
# Frameworks & Dependencies
# -------------------------------------------------------------------------
node_modules/
jspm_packages/
.npm/
.yarn/
.pnp
.pnp.js

# -------------------------------------------------------------------------
# Build & Output (NestJS, Vite, React)
# -------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.vuepress/
.serverless/
.out/
.cache/
.vite/
api/dist/
web/dist/

# -------------------------------------------------------------------------
# Logs & Debugging
# -------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
.pnpm-debug.log*

# -------------------------------------------------------------------------
# Testing & Coverage
# -------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -------------------------------------------------------------------------
# Prisma (Database)
# -------------------------------------------------------------------------
# Ignorar las carpetas locales generadas si las has personalizado en un path
# (Aunque por defecto caen en node_modules/@prisma que ya está ignorado arriba)
prisma/*.db
prisma/*.db-journal

# -------------------------------------------------------------------------
# IDEs & System Files
# -------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
