# Pitaya Vision — Environment Variables Template
# Copy to .env and fill in real values

# API
PORT=3016
DATABASE_URL="mysql://root:{db_password}@localhost:3306/pitayavisual_db"
VECTOR_DATABASE_URL="postgresql://{pg_user}:{pg_password}@localhost:5434/pitayavisual_vector"
JWT_SECRET="{your_jwt_secret}"

# PitayaCore Remote Agent (ALWAYS use production)
PITAYACORE_URL="https://pitayacore-api.pitayacode.io"
PITAYACORE_API_KEY="{your_pitayacore_api_key}"

# Fal.ai
FAL_KEY="{your_fal_api_key}"

# Cloudflare R2
R2_ACCOUNT_ID="{your_r2_account_id}"
R2_ACCESS_KEY_ID="{your_r2_access_key_id}"
R2_SECRET_ACCESS_KEY="{your_r2_secret_access_key}"
R2_BUCKET_NAME="vision"
R2_PUBLIC_URL="{your_r2_public_url}"
